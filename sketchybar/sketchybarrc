#!/usr/bin/env bash

source "$CONFIG_DIR/colors.sh"

# ============================================================
# Bar appearance
#   macOS デフォルトメニューバーに寄せたフラットな構成。
# ============================================================
sketchybar --bar height=28 \
                 blur_radius=70 \
                 position=top \
                 sticky=on \
                 padding_left=8 \
                 padding_right=8 \
                 color=$BAR_COLOR

# ============================================================
# Defaults
#   アイコン・ラベル共に Apple 純正の SF Pro を使用（SF Symbols 描画用）。
# ============================================================
sketchybar --add event aerospace_workspace_change
sketchybar --add event aerospace_mode_change
sketchybar --add event input_method_change

sketchybar --default updates=on \
                    icon.font="SF Pro:Bold:14.0" \
                    icon.color=$ICON_COLOR \
                    label.font="SF Pro:Semibold:13.0" \
                    label.color=$LABEL_COLOR \
                    padding_left=4 \
                    padding_right=4 \
                    icon.padding_left=4 \
                    icon.padding_right=4 \
                    label.padding_left=4 \
                    label.padding_right=4 \
                    background.drawing=off

# ============================================================
# Aerospace workspace indicators
#   spaces.sh が動的に space.X を追加する。
# ============================================================
sketchybar --add event aerospace_init

sketchybar --add item spaces_manager left \
           --set spaces_manager \
                drawing=off \
                script="$CONFIG_DIR/plugins/spaces.sh" \
           --subscribe spaces_manager aerospace_init aerospace_workspace_change

sketchybar --trigger aerospace_init

# ============================================================
# Aerospace mode indicator (service mode 中のみ表示)
# ============================================================
sketchybar --add item aerospace_mode left \
           --set aerospace_mode \
                drawing=off \
                background.color=0xffbf616a \
                background.corner_radius=4 \
                background.height=20 \
                background.drawing=on \
                icon.drawing=off \
                label.font="SF Pro:Bold:12.0" \
                label.color=0xffeceff4 \
                label.padding_left=8 \
                label.padding_right=8 \
                script="$CONFIG_DIR/plugins/aerospace_mode.sh" \
           --subscribe aerospace_mode aerospace_mode_change

# ============================================================
# Front app
# ============================================================
sketchybar --add item front_app left \
           --set front_app \
                update_freq=3 \
                icon.drawing=on \
                icon.font="sketchybar-app-font:Regular:16.0" \
                icon.color=$LABEL_COLOR \
                icon.padding_left=8 \
                icon.padding_right=4 \
                label.font="SF Pro:Semibold:13.0" \
                label.color=$LABEL_COLOR \
                label.padding_left=4 \
                label.padding_right=4 \
                script="$CONFIG_DIR/plugins/front_app.sh" \
           --subscribe front_app front_app_switched aerospace_workspace_change

# ============================================================
# 中央: 音楽情報（再生中のみ表示）
# ============================================================
sketchybar --add item music center \
           --set music \
                drawing=off \
                update_freq=5 \
                icon.font="SF Pro:Bold:14.0" \
                icon.color=$ICON_COLOR \
                icon.padding_right=4 \
                label.font="SF Pro:Medium:13.0" \
                label.color=$LABEL_COLOR \
                click_script="osascript -e 'tell application \"Spotify\" to playpause' 2>/dev/null || osascript -e 'tell application \"Music\" to playpause' 2>/dev/null" \
                script="$CONFIG_DIR/plugins/music.sh" \
           --subscribe music media_change

# ============================================================
# 右側: IME → Wi-Fi → Volume → Battery → Clock
#   全てフラット（背景なし）。アイコンは SF Symbols で macOS 標準に寄せる。
#   right セクションは最初に add したものが画面左端に並ぶ。
# ============================================================

# IME (日英入力状態)
#   watcher が input_method_change イベントを即時発火する。
#   フォールバックとして update_freq=10 のポーリングも残す。
sketchybar --add item input_method right \
           --set input_method \
                update_freq=10 \
                icon.drawing=off \
                label.font="SF Pro:Bold:13.0" \
                label.color=$LABEL_COLOR \
                script="$CONFIG_DIR/plugins/input_method.sh" \
           --subscribe input_method input_method_change

# Wi-Fi
sketchybar --add item wifi right \
           --set wifi \
                update_freq=10 \
                icon.font="SF Pro:Bold:15.0" \
                click_script="open '/System/Library/PreferencePanes/Network.prefPane'" \
                script="$CONFIG_DIR/plugins/wifi.sh" \
           --subscribe wifi system_woke wifi_change

# Volume
sketchybar --add item volume right \
           --set volume \
                update_freq=5 \
                icon.font="SF Pro:Bold:15.0" \
                click_script="open '/System/Library/PreferencePanes/Sound.prefPane'" \
                script="$CONFIG_DIR/plugins/volume.sh" \
           --subscribe volume volume_change

# Battery
sketchybar --add item battery right \
           --set battery \
                update_freq=60 \
                icon.font="SF Pro:Bold:16.0" \
                click_script="open '/System/Library/PreferencePanes/Battery.prefPane'" \
                script="$CONFIG_DIR/plugins/battery.sh" \
           --subscribe battery system_woke power_source_change

# Clock
sketchybar --add item clock right \
           --set clock \
                update_freq=1 \
                icon.drawing=off \
                label.font="SF Pro:Semibold:13.0" \
                label.color=$LABEL_COLOR \
                script="$CONFIG_DIR/plugins/clock.sh"

# ============================================================
# Force update
# ============================================================
sketchybar --update

# ============================================================
# IME watcher: 0.2 秒間隔で im-select を監視し、変化時に
# input_method_change イベントを発火する。
# 既存の watcher を停止してから新規起動して重複を防ぐ。
# ============================================================
pkill -f "input_method_watcher.sh" 2>/dev/null
"$CONFIG_DIR/plugins/input_method_watcher.sh" >/dev/null 2>&1 &
disown
